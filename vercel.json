{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.calculadorafiausmp.com"
        }
      ],
      "destination": "https://calculadorafiausmp.com/:path*",
      "permanent": true
    }
  ]
}